{
  "name": "haido",
  "version": "0.2.1",
  "description": "A captain's log for AI coding agents — memories anchored to code, aware of their own staleness. (Hải Đồ)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lebac-svg/haido.git"
  },
  "homepage": "https://github.com/lebac-svg/haido#readme",
  "bugs": {
    "url": "https://github.com/lebac-svg/haido/issues"
  },
  "bin": {
    "haido": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai-agents",
    "claude-code",
    "code-map",
    "knowledge-management"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "web-tree-sitter": "^0.26.10",
    "zod": "^3.25.76"
  }
}
